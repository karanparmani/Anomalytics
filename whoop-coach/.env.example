# Public HTTPS origin of this service, without a trailing slash.
PUBLIC_BASE_URL=https://whoop-coach.example.com
PORT=8787

# Auth0 secures the MCP endpoint for this personal app.
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com/
AUTH0_AUDIENCE=https://whoop-coach.example.com
# Optional but strongly recommended: restrict the app to your Auth0 subject.
AUTH0_ALLOWED_SUBJECT=

# Create an app at https://developer-dashboard.whoop.com/
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://whoop-coach.example.com/oauth/whoop/callback
WHOOP_SCOPES=offline read:profile read:cycles read:recovery read:sleep read:workout read:body_measurement

# PostgreSQL and encryption. TOKEN_ENCRYPTION_KEY must decode to exactly 32 bytes.
DATABASE_URL=postgresql://whoop:whoop@localhost:5432/whoop_coach
TOKEN_ENCRYPTION_KEY=

# Reconcile recent records hourly; webhook events update sooner.
WHOOP_RECONCILIATION_CRON=7 * * * *
WHOOP_RECONCILIATION_LOOKBACK_DAYS=7
WHOOP_INITIAL_SYNC_DAYS=90
